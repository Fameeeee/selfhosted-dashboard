# ── API service ───────────────────────────────────────────────
# Secret used to validate GitHub webhook HMAC signatures
WEBHOOK_SECRET=1bcb698a4eee9f2172d409965b1e6c1cb7db961ef9899fea1e976ee258bd30e2
# ── Worker service ────────────────────────────────────────────
# Number of concurrent scan goroutines
WORKERS=4

# Redis queue key (must match API service)
QUEUE_KEY=webhook_jobs

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production only — required when redis requirepass is set
REDIS_PASSWORD=

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=secretscanner
POSTGRES_USER=scanner
POSTGRES_PASSWORD=fame123456
DATABASE_URL=postgres://scanner:fame123456@localhost:5432/secretscanner?sslmode=disable

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── CD / GHCR ─────────────────────────────────────────────────
# Set automatically in GitHub Actions; override locally if needed
# GITHUB_REPOSITORY=org/repo
# IMAGE_TAG=latest

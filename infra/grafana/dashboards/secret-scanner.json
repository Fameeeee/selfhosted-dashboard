{
  "title": "Secret Scanner",
  "uid": "secret-scanner",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Findings",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(secret_scanner_findings_total)",
          "legendFormat": "Findings"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Webhooks Received (1h)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(secret_scanner_webhooks_total[1h])",
          "legendFormat": "Webhooks"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "secret_scanner_queue_depth",
          "legendFormat": "webhook_jobs"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Scan Duration (p95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(secret_scanner_scan_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
